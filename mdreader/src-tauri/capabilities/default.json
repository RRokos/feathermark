{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "file-*"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-exists",
    "dialog:default",
    "dialog:allow-open"
  ]
}
